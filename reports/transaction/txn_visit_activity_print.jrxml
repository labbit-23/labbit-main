  <parameter name="visit_id" class="java.lang.String"/><parameter name="lab_name" class="java.lang.String"/><parameter name="REPORT_LOGO_URL" class="java.lang.String" isForPrompting="false"/>
  <queryString><![CDATA[select created_at, changed_by_role, activity_type, remark from visit_activity_log where visit_id::text = $P{visit_id} order by created_at desc]]></queryString>
  <field name="created_at" class="java.sql.Timestamp"/><field name="changed_by_role" class="java.lang.String"/><field name="activity_type" class="java.lang.String"/><field name="remark" class="java.lang.String"/>
  <title><band height="62"><image onErrorType="Blank"><reportElement x="0" y="0" width="56" height="40"/><imageExpression><![CDATA[$P{REPORT_LOGO_URL} == null || $P{REPORT_LOGO_URL}.trim().isEmpty() ? null : new java.net.URL($P{REPORT_LOGO_URL})]]></imageExpression></image><staticText><reportElement x="60" y="0" width="742" height="24"/><textElement textAlignment="Center"><font size="14" isBold="true"/></textElement><text><![CDATA[Visit Activity Timeline]]></text></staticText><textField><reportElement x="60" y="24" width="742" height="16"/><textElement textAlignment="Center"><font size="10"/></textElement><textFieldExpression><![CDATA["Lab: " + $P{lab_name}]]></textFieldExpression></textField><textField><reportElement x="60" y="42" width="742" height="16"/><textElement textAlignment="Center"><font size="10"/></textElement><textFieldExpression><![CDATA["Visit ID: " + $P{visit_id}]]></textFieldExpression></textField></band></title>
