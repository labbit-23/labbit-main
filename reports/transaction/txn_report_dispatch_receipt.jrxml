  <parameter name="dispatch_log_id" class="java.lang.String"/><parameter name="lab_name" class="java.lang.String"/><parameter name="REPORT_LOGO_URL" class="java.lang.String" isForPrompting="false"/>
  <queryString><![CDATA[select id, reqid, reqno, actor_name, actor_role, status, result_message, created_at from report_dispatch_logs where id::text = $P{dispatch_log_id}]]></queryString>
