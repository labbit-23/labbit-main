<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="txn_whatsapp_conversation_print" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" whenNoDataType="AllSectionsNoDetail" uuid="6b4684f3-1b7f-43ac-9187-0c628cebc73d">
  <parameter name="lab_id" class="java.lang.String"/><parameter name="lab_name" class="java.lang.String"/><parameter name="phone" class="java.lang.String"/><parameter name="from_date" class="java.sql.Date"/><parameter name="to_date" class="java.sql.Date"/><parameter name="REPORT_LOGO_URL" class="java.lang.String" isForPrompting="false"/>
  <queryString><![CDATA[select created_at, direction, message_type, body, media_url from whatsapp_messages where lab_id::text = $P{lab_id} and phone = $P{phone} and date(created_at) between $P{from_date} and $P{to_date} order by created_at]]></queryString>
  <field name="created_at" class="java.sql.Timestamp"/><field name="direction" class="java.lang.String"/><field name="message_type" class="java.lang.String"/><field name="body" class="java.lang.String"/><field name="media_url" class="java.lang.String"/>
  <title><band height="62"><image onErrorType="Blank"><reportElement x="0" y="0" width="56" height="40"/><imageExpression><![CDATA[$P{REPORT_LOGO_URL} == null || $P{REPORT_LOGO_URL}.trim().isEmpty() ? null : new java.net.URL($P{REPORT_LOGO_URL})]]></imageExpression></image><staticText><reportElement x="60" y="0" width="742" height="24"/><textElement textAlignment="Center"><font size="14" isBold="true"/></textElement><text><![CDATA[WhatsApp Conversation Transcript]]></text></staticText><textField><reportElement x="60" y="24" width="742" height="16"/><textElement textAlignment="Center"><font size="10"/></textElement><textFieldExpression><![CDATA["Lab: " + $P{lab_name} + " | Phone: " + $P{phone}]]></textFieldExpression></textField><textField><reportElement x="60" y="42" width="742" height="16"/><textElement textAlignment="Center"><font size="10"/></textElement><textFieldExpression><![CDATA["Date: " + $P{from_date} + " to " + $P{to_date}]]></textFieldExpression></textField></band></title>
  <columnHeader><band height="22"><staticText><reportElement x="0" y="0" width="120" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[At]]></text></staticText><staticText><reportElement x="120" y="0" width="100" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Direction]]></text></staticText><staticText><reportElement x="220" y="0" width="110" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Type]]></text></staticText><staticText><reportElement x="330" y="0" width="332" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Message]]></text></staticText><staticText><reportElement x="662" y="0" width="140" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Media URL]]></text></staticText></band></columnHeader>
  <detail><band height="20"><textField pattern="dd-MMM HH:mm"><reportElement x="0" y="0" width="120" height="20"/><textFieldExpression><![CDATA[$F{created_at}]]></textFieldExpression></textField><textField><reportElement x="120" y="0" width="100" height="20"/><textFieldExpression><![CDATA[$F{direction}]]></textFieldExpression></textField><textField><reportElement x="220" y="0" width="110" height="20"/><textFieldExpression><![CDATA[$F{message_type}]]></textFieldExpression></textField><textField><reportElement x="330" y="0" width="332" height="20"/><textFieldExpression><![CDATA[$F{body}]]></textFieldExpression></textField><textField><reportElement x="662" y="0" width="140" height="20"/><textFieldExpression><![CDATA[$F{media_url}]]></textFieldExpression></textField></band></detail>
