<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="txn_sample_pickup_slip" pageWidth="595" pageHeight="842" orientation="Portrait" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" whenNoDataType="AllSectionsNoDetail" uuid="0f1af0d7-bc7a-4fde-8fe7-cf3f7d4ce022">
  <parameter name="lab_id" class="java.lang.String"/><parameter name="lab_name" class="java.lang.String"/><parameter name="pickup_id" class="java.lang.String"/><parameter name="REPORT_LOGO_URL" class="java.lang.String" isForPrompting="false"/>
  <queryString><![CDATA[select sp.id, sp.status, sp.created_at, sp.picked_up_at, sp.dropped_off_at, cc.name as centre_name from sample_pickups sp left join collection_centre cc on cc.id = sp.collection_centre_id where sp.id::text = $P{pickup_id} and sp.lab_id::text = $P{lab_id}]]></queryString>
  <field name="id" class="java.lang.String"/><field name="status" class="java.lang.String"/><field name="created_at" class="java.sql.Timestamp"/><field name="picked_up_at" class="java.sql.Timestamp"/><field name="dropped_off_at" class="java.sql.Timestamp"/><field name="centre_name" class="java.lang.String"/>
  <title><band height="62"><image onErrorType="Blank"><reportElement x="0" y="0" width="56" height="40"/><imageExpression><![CDATA[$P{REPORT_LOGO_URL} == null || $P{REPORT_LOGO_URL}.trim().isEmpty() ? null : new java.net.URL($P{REPORT_LOGO_URL})]]></imageExpression></image><staticText><reportElement x="60" y="0" width="495" height="24"/><textElement textAlignment="Center"><font size="14" isBold="true"/></textElement><text><![CDATA[Sample Pickup Slip]]></text></staticText><textField><reportElement x="60" y="24" width="495" height="16"/><textElement textAlignment="Center"><font size="10"/></textElement><textFieldExpression><![CDATA["Lab: " + $P{lab_name}]]></textFieldExpression></textField><textField><reportElement x="60" y="42" width="495" height="16"/><textElement textAlignment="Center"><font size="10"/></textElement><textFieldExpression><![CDATA["Pickup ID: " + $P{pickup_id}]]></textFieldExpression></textField></band></title>
  <detail><band height="150"><staticText><reportElement x="0" y="0" width="170" height="22"/><textElement><font isBold="true"/></textElement><text><![CDATA[Centre]]></text></staticText><textField><reportElement x="170" y="0" width="385" height="22"/><textFieldExpression><![CDATA[$F{centre_name}]]></textFieldExpression></textField><staticText><reportElement x="0" y="24" width="170" height="22"/><textElement><font isBold="true"/></textElement><text><![CDATA[Status]]></text></staticText><textField><reportElement x="170" y="24" width="385" height="22"/><textFieldExpression><![CDATA[$F{status}]]></textFieldExpression></textField><staticText><reportElement x="0" y="48" width="170" height="22"/><textElement><font isBold="true"/></textElement><text><![CDATA[Created]]></text></staticText><textField pattern="dd-MMM HH:mm"><reportElement x="170" y="48" width="385" height="22"/><textFieldExpression><![CDATA[$F{created_at}]]></textFieldExpression></textField><staticText><reportElement x="0" y="72" width="170" height="22"/><textElement><font isBold="true"/></textElement><text><![CDATA[Picked]]></text></staticText><textField pattern="dd-MMM HH:mm"><reportElement x="170" y="72" width="385" height="22"/><textFieldExpression><![CDATA[$F{picked_up_at}]]></textFieldExpression></textField><staticText><reportElement x="0" y="96" width="170" height="22"/><textElement><font isBold="true"/></textElement><text><![CDATA[Dropped]]></text></staticText><textField pattern="dd-MMM HH:mm"><reportElement x="170" y="96" width="385" height="22"/><textFieldExpression><![CDATA[$F{dropped_off_at}]]></textFieldExpression></textField></band></detail>
