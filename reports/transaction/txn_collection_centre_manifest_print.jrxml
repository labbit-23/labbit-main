<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="txn_collection_centre_manifest_print" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" whenNoDataType="AllSectionsNoDetail" uuid="13f4078b-ea09-46a7-aad9-2c0eb8f6a764">
  <parameter name="lab_id" class="java.lang.String"/><parameter name="lab_name" class="java.lang.String"/><parameter name="collection_centre_id" class="java.lang.String"/><parameter name="for_date" class="java.sql.Date"/><parameter name="REPORT_LOGO_URL" class="java.lang.String" isForPrompting="false"/>
  <queryString><![CDATA[select sp.id, sp.status, sp.created_at, cc.name as centre_name from sample_pickups sp left join collection_centre cc on cc.id = sp.collection_centre_id where sp.lab_id::text = $P{lab_id} and sp.collection_centre_id::text = $P{collection_centre_id} and date(sp.created_at) = $P{for_date} order by sp.created_at]]></queryString>
  <field name="id" class="java.lang.String"/><field name="status" class="java.lang.String"/><field name="created_at" class="java.sql.Timestamp"/><field name="centre_name" class="java.lang.String"/>
  <title><band height="62"><image onErrorType="Blank"><reportElement x="0" y="0" width="56" height="40"/><imageExpression><![CDATA[$P{REPORT_LOGO_URL} == null || $P{REPORT_LOGO_URL}.trim().isEmpty() ? null : new java.net.URL($P{REPORT_LOGO_URL})]]></imageExpression></image><staticText><reportElement x="60" y="0" width="742" height="24"/><textElement textAlignment="Center"><font size="14" isBold="true"/></textElement><text><![CDATA[Collection Centre Manifest]]></text></staticText><textField><reportElement x="60" y="24" width="742" height="16"/><textElement textAlignment="Center"><font size="10"/></textElement><textFieldExpression><![CDATA["Lab: " + $P{lab_name}]]></textFieldExpression></textField><textField><reportElement x="60" y="42" width="742" height="16"/><textElement textAlignment="Center"><font size="10"/></textElement><textFieldExpression><![CDATA["Date: " + $P{for_date}]]></textFieldExpression></textField></band></title>
  <columnHeader><band height="22"><staticText><reportElement x="0" y="0" width="150" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Pickup ID]]></text></staticText><staticText><reportElement x="150" y="0" width="352" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Centre]]></text></staticText><staticText><reportElement x="502" y="0" width="140" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Status]]></text></staticText><staticText><reportElement x="642" y="0" width="160" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Created At]]></text></staticText></band></columnHeader>
  <detail><band height="20"><textField><reportElement x="0" y="0" width="150" height="20"/><textFieldExpression><![CDATA[$F{id}]]></textFieldExpression></textField><textField><reportElement x="150" y="0" width="352" height="20"/><textFieldExpression><![CDATA[$F{centre_name}]]></textFieldExpression></textField><textField><reportElement x="502" y="0" width="140" height="20"/><textFieldExpression><![CDATA[$F{status}]]></textFieldExpression></textField><textField pattern="dd-MMM HH:mm"><reportElement x="642" y="0" width="160" height="20"/><textFieldExpression><![CDATA[$F{created_at}]]></textFieldExpression></textField></band></detail>
</jasperReport>
