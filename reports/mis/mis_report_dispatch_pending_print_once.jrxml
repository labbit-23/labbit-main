  <parameter name="lab_id" class="java.lang.String"/><parameter name="lab_name" class="java.lang.String"/>
  <queryString><![CDATA[select reqno, reqid, patient_phone, pending_ready_keys, created_at from report_dispatch_logs where lab_id::text = $P{lab_id} and status = 'pending' order by created_at desc]]></queryString>
  <field name="reqno" class="java.lang.String"/><field name="reqid" class="java.lang.String"/><field name="patient_phone" class="java.lang.String"/><field name="pending_ready_keys" class="java.lang.String"/><field name="created_at" class="java.sql.Timestamp"/>
