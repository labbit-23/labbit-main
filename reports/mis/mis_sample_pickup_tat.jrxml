<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="mis_sample_pickup_tat" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" whenNoDataType="AllSectionsNoDetail" uuid="8b18bd14-c89f-4f12-8cc2-2062f021be0c">
  <parameter name="lab_id" class="java.lang.String"/><parameter name="lab_name" class="java.lang.String"/><parameter name="from_date" class="java.sql.Date"/><parameter name="to_date" class="java.sql.Date"/>
  <queryString><![CDATA[select sp.id, sp.status, sp.created_at, sp.picked_up_at, sp.dropped_off_at, cc.name as centre_name from sample_pickups sp left join collection_centre cc on cc.id = sp.collection_centre_id where sp.lab_id::text = $P{lab_id} and date(sp.created_at) between $P{from_date} and $P{to_date} order by sp.created_at desc]]></queryString>
  <field name="id" class="java.lang.String"/><field name="status" class="java.lang.String"/><field name="created_at" class="java.sql.Timestamp"/><field name="picked_up_at" class="java.sql.Timestamp"/><field name="dropped_off_at" class="java.sql.Timestamp"/><field name="centre_name" class="java.lang.String"/>
  <title><band height="44"><staticText><reportElement x="0" y="0" width="802" height="24"/><textElement textAlignment="Center"><font size="14" isBold="true"/></textElement><text><![CDATA[Sample Pickup TAT]]></text></staticText><textField><reportElement x="0" y="26" width="802" height="16"/><textElement textAlignment="Center"><font size="10"/></textElement><textFieldExpression><![CDATA["Lab: " + $P{lab_name} + " | Date: " + $P{from_date} + " to " + $P{to_date}]]></textFieldExpression></textField></band></title>
  <columnHeader><band height="22"><staticText><reportElement x="0" y="0" width="80" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[ID]]></text></staticText><staticText><reportElement x="80" y="0" width="220" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Centre]]></text></staticText><staticText><reportElement x="300" y="0" width="90" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Status]]></text></staticText><staticText><reportElement x="390" y="0" width="138" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Created]]></text></staticText><staticText><reportElement x="528" y="0" width="138" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Picked]]></text></staticText><staticText><reportElement x="666" y="0" width="136" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Dropped]]></text></staticText></band></columnHeader>
