<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="mis_collection_centre_productivity" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" whenNoDataType="AllSectionsNoDetail" uuid="87dcdff2-436c-42d7-8d9a-0f8a160e9113">
  <parameter name="lab_id" class="java.lang.String"/><parameter name="lab_name" class="java.lang.String"/><parameter name="from_date" class="java.sql.Date"/><parameter name="to_date" class="java.sql.Date"/>
  <queryString><![CDATA[select cc.name as centre_name, count(sp.id) as pickups, count(*) filter (where lower(coalesce(sp.status,''))='dropped') as dropped_count from collection_centre cc left join sample_pickups sp on sp.collection_centre_id = cc.id where cc.lab_id::text = $P{lab_id} and date(coalesce(sp.created_at, now())) between $P{from_date} and $P{to_date} group by 1 order by 2 desc]]></queryString>
  <field name="centre_name" class="java.lang.String"/><field name="pickups" class="java.lang.Long"/><field name="dropped_count" class="java.lang.Long"/>
  <title><band height="44"><staticText><reportElement x="0" y="0" width="802" height="24"/><textElement textAlignment="Center"><font size="14" isBold="true"/></textElement><text><![CDATA[Collection Centre Productivity]]></text></staticText><textField><reportElement x="0" y="26" width="802" height="16"/><textElement textAlignment="Center"><font size="10"/></textElement><textFieldExpression><![CDATA["Lab: " + $P{lab_name} + " | Date: " + $P{from_date} + " to " + $P{to_date}]]></textFieldExpression></textField></band></title>
  <columnHeader><band height="22"><staticText><reportElement x="0" y="0" width="500" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Collection Centre]]></text></staticText><staticText><reportElement x="500" y="0" width="150" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Pickups]]></text></staticText><staticText><reportElement x="650" y="0" width="152" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Dropped]]></text></staticText></band></columnHeader>
  <detail><band height="20"><textField><reportElement x="0" y="0" width="500" height="20"/><textFieldExpression><![CDATA[$F{centre_name}]]></textFieldExpression></textField><textField><reportElement x="500" y="0" width="150" height="20"/><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{pickups}]]></textFieldExpression></textField><textField><reportElement x="650" y="0" width="152" height="20"/><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{dropped_count}]]></textFieldExpression></textField></band></detail>
</jasperReport>
