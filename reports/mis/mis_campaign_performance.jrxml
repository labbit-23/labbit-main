<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="mis_campaign_performance" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" whenNoDataType="AllSectionsNoDetail" uuid="92c13cb8-e4f4-4d7a-b8db-4e21371d64e4">
  <parameter name="lab_id" class="java.lang.String"/><parameter name="lab_name" class="java.lang.String"/><parameter name="from_date" class="java.sql.Date"/><parameter name="to_date" class="java.sql.Date"/>
  <queryString><![CDATA[select c.name as campaign_name, c.status as campaign_status, count(cr.id) as recipients, count(*) filter (where lower(coalesce(cr.status,''))='sent') as sent_count, count(*) filter (where lower(coalesce(cr.status,''))='failed') as failed_count from campaigns c left join campaign_recipients cr on cr.campaign_id = c.id where c.lab_id::text = $P{lab_id} and date(c.created_at) between $P{from_date} and $P{to_date} group by 1,2 order by c.name]]></queryString>
  <field name="campaign_name" class="java.lang.String"/><field name="campaign_status" class="java.lang.String"/><field name="recipients" class="java.lang.Long"/><field name="sent_count" class="java.lang.Long"/><field name="failed_count" class="java.lang.Long"/>
  <title><band height="44"><staticText><reportElement x="0" y="0" width="802" height="24"/><textElement textAlignment="Center"><font size="14" isBold="true"/></textElement><text><![CDATA[Campaign Performance]]></text></staticText><textField><reportElement x="0" y="26" width="802" height="16"/><textElement textAlignment="Center"><font size="10"/></textElement><textFieldExpression><![CDATA["Lab: " + $P{lab_name} + " | Date: " + $P{from_date} + " to " + $P{to_date}]]></textFieldExpression></textField></band></title>
  <columnHeader><band height="22"><staticText><reportElement x="0" y="0" width="300" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Campaign]]></text></staticText><staticText><reportElement x="300" y="0" width="120" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Status]]></text></staticText><staticText><reportElement x="420" y="0" width="126" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Recipients]]></text></staticText><staticText><reportElement x="546" y="0" width="128" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Sent]]></text></staticText><staticText><reportElement x="674" y="0" width="128" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Failed]]></text></staticText></band></columnHeader>
  <detail><band height="20"><textField><reportElement x="0" y="0" width="300" height="20"/><textFieldExpression><![CDATA[$F{campaign_name}]]></textFieldExpression></textField><textField><reportElement x="300" y="0" width="120" height="20"/><textFieldExpression><![CDATA[$F{campaign_status}]]></textFieldExpression></textField><textField><reportElement x="420" y="0" width="126" height="20"/><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{recipients}]]></textFieldExpression></textField><textField><reportElement x="546" y="0" width="128" height="20"/><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{sent_count}]]></textFieldExpression></textField><textField><reportElement x="674" y="0" width="128" height="20"/><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{failed_count}]]></textFieldExpression></textField></band></detail>
</jasperReport>
