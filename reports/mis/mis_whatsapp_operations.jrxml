<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="mis_whatsapp_operations" pageWidth="595" pageHeight="842" orientation="Portrait" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" whenNoDataType="AllSectionsNoDetail" uuid="4421cb7f-047e-4f2e-bd4c-28644da8715d">
  <parameter name="lab_id" class="java.lang.String"/><parameter name="lab_name" class="java.lang.String"/><parameter name="from_date" class="java.sql.Date"/><parameter name="to_date" class="java.sql.Date"/>
  <queryString><![CDATA[select date(created_at) as log_date, direction, count(*) as messages from whatsapp_messages where lab_id::text = $P{lab_id} and date(created_at) between $P{from_date} and $P{to_date} group by 1,2 order by 1,2]]></queryString>
  <field name="log_date" class="java.sql.Date"/><field name="direction" class="java.lang.String"/><field name="messages" class="java.lang.Long"/>
  <title><band height="44"><staticText><reportElement x="0" y="0" width="555" height="24"/><textElement textAlignment="Center"><font size="14" isBold="true"/></textElement><text><![CDATA[WhatsApp Operations Summary]]></text></staticText><textField><reportElement x="0" y="26" width="555" height="16"/><textElement textAlignment="Center"><font size="10"/></textElement><textFieldExpression><![CDATA["Lab: " + $P{lab_name} + " | Date: " + $P{from_date} + " to " + $P{to_date}]]></textFieldExpression></textField></band></title>
  <columnHeader><band height="22"><staticText><reportElement x="0" y="0" width="180" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Date]]></text></staticText><staticText><reportElement x="180" y="0" width="180" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Direction]]></text></staticText><staticText><reportElement x="360" y="0" width="195" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Messages]]></text></staticText></band></columnHeader>
  <detail><band height="20"><textField pattern="dd-MMM-yyyy"><reportElement x="0" y="0" width="180" height="20"/><textFieldExpression><![CDATA[$F{log_date}]]></textFieldExpression></textField><textField><reportElement x="180" y="0" width="180" height="20"/><textFieldExpression><![CDATA[$F{direction}]]></textFieldExpression></textField><textField><reportElement x="360" y="0" width="195" height="20"/><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{messages}]]></textFieldExpression></textField></band></detail>
</jasperReport>
