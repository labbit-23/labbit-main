<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="mis_cto_service_health" pageWidth="595" pageHeight="842" orientation="Portrait" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" whenNoDataType="AllSectionsNoDetail" uuid="69c2d607-4097-4257-b1fb-8d4547456398">
  <parameter name="lab_id" class="java.lang.String"/><parameter name="lab_name" class="java.lang.String"/><parameter name="from_date" class="java.sql.Date"/><parameter name="to_date" class="java.sql.Date"/>
  <queryString><![CDATA[select service_name, count(*) as log_rows, max(created_at) as last_event_at from cto_service_logs where lab_id::text = $P{lab_id} and date(created_at) between $P{from_date} and $P{to_date} group by 1 order by 1]]></queryString>
  <field name="service_name" class="java.lang.String"/><field name="log_rows" class="java.lang.Long"/><field name="last_event_at" class="java.sql.Timestamp"/>
  <title><band height="44"><staticText><reportElement x="0" y="0" width="555" height="24"/><textElement textAlignment="Center"><font size="14" isBold="true"/></textElement><text><![CDATA[CTO Service Health]]></text></staticText><textField><reportElement x="0" y="26" width="555" height="16"/><textElement textAlignment="Center"><font size="10"/></textElement><textFieldExpression><![CDATA["Lab: " + $P{lab_name} + " | Date: " + $P{from_date} + " to " + $P{to_date}]]></textFieldExpression></textField></band></title>
  <columnHeader><band height="22"><staticText><reportElement x="0" y="0" width="255" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Service]]></text></staticText><staticText><reportElement x="255" y="0" width="120" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Logs]]></text></staticText><staticText><reportElement x="375" y="0" width="180" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Last Event]]></text></staticText></band></columnHeader>
  <detail><band height="20"><textField><reportElement x="0" y="0" width="255" height="20"/><textFieldExpression><![CDATA[$F{service_name}]]></textFieldExpression></textField><textField><reportElement x="255" y="0" width="120" height="20"/><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{log_rows}]]></textFieldExpression></textField><textField pattern="dd-MMM HH:mm"><reportElement x="375" y="0" width="180" height="20"/><textFieldExpression><![CDATA[$F{last_event_at}]]></textFieldExpression></textField></band></detail>
</jasperReport>
