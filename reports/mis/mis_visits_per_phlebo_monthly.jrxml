<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
  name="mis_visits_per_phlebo_monthly" pageWidth="842" pageHeight="595" orientation="Landscape"
  columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
  whenNoDataType="AllSectionsNoDetail" uuid="9579045e-c401-4ee8-8f9a-2c76c30ea1e6">

  <parameter name="lab_id" class="java.lang.String"/>
  <parameter name="lab_name" class="java.lang.String"/>
  <parameter name="from_date" class="java.sql.Date"/>
  <parameter name="to_date" class="java.sql.Date"/>

  <queryString><![CDATA[
    select
      to_char(v.visit_date::date,'YYYY-MM') as month_key,
      coalesce(e.name, 'Unassigned') as executive_name,
      count(*) as total_visits,
      count(*) filter (where lower(coalesce(v.status,'')) = 'completed') as completed_visits,
      count(*) filter (where lower(coalesce(v.status,'')) in ('cancelled','canceled','disabled')) as cancelled_visits
    from visits v
    left join executives e on e.id = v.executive_id
    where v.lab_id::text = $P{lab_id}
      and v.visit_date between $P{from_date} and $P{to_date}
    group by 1,2
    order by 1,2
  ]]></queryString>

  <field name="month_key" class="java.lang.String"/>
  <field name="executive_name" class="java.lang.String"/>
  <field name="total_visits" class="java.lang.Long"/>
  <field name="completed_visits" class="java.lang.Long"/>
  <field name="cancelled_visits" class="java.lang.Long"/>

  <title>
    <band height="44">
      <staticText><reportElement x="0" y="0" width="802" height="24"/><textElement textAlignment="Center"><font size="14" isBold="true"/></textElement><text><![CDATA[Visits Per Phlebo Monthly]]></text></staticText>
      <textField><reportElement x="0" y="26" width="802" height="16"/><textElement textAlignment="Center"><font size="10"/></textElement><textFieldExpression><![CDATA["Lab: " + $P{lab_name} + " | Date: " + $P{from_date} + " to " + $P{to_date}]]></textFieldExpression></textField>
    </band>
  </title>

  <columnHeader>
    <band height="22">
      <staticText><reportElement x="0" y="0" width="180" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Month]]></text></staticText>
      <staticText><reportElement x="180" y="0" width="300" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Phlebo]]></text></staticText>
      <staticText><reportElement x="480" y="0" width="110" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Total Visits]]></text></staticText>
      <staticText><reportElement x="590" y="0" width="110" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Completed]]></text></staticText>
      <staticText><reportElement x="700" y="0" width="102" height="22" backcolor="#E9EDF5" mode="Opaque"/><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Cancelled]]></text></staticText>
    </band>
  </columnHeader>

  <detail>
    <band height="20">
      <textField><reportElement x="0" y="0" width="180" height="20"/><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{month_key}]]></textFieldExpression></textField>
      <textField><reportElement x="180" y="0" width="300" height="20"/><textElement textAlignment="Left"/><textFieldExpression><![CDATA[$F{executive_name}]]></textFieldExpression></textField>
      <textField><reportElement x="480" y="0" width="110" height="20"/><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{total_visits}]]></textFieldExpression></textField>
      <textField><reportElement x="590" y="0" width="110" height="20"/><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{completed_visits}]]></textFieldExpression></textField>
      <textField><reportElement x="700" y="0" width="102" height="20"/><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{cancelled_visits}]]></textFieldExpression></textField>
    </band>
  </detail>

</jasperReport>
